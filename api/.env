## `.env` file is used to set up global environmental arguments

HOST=0.0.0.0
PORT=12244

DEBUG=1
CUDA_VISIBLE_DEVICES=0

## cosyvoice2, cosyvoice2_stepaudio_whole, cosyvoice2_stepaudio_stream, cosyvoice3
VERSION=cosyvoice3
TTS_MODEL_DIR=../assets/Fun-CosyVoice3-0.5B-2512
DEFAULT_SPEAKER_CACHE_PATH=../assets/default_speaker_cache.pt
CONFIG_PATH=./config.yaml
## `FRONTEND_MODE` supports `ttsfrd` and `wetext`.
FRONTEND_MODE=wetext
TTSFRD_RESOURCE_PATH=../assets/CosyVoice-ttsfrd/resource
NOVASR_MODEL_PATH=../assets/novasr_v2.bin
TORCH_CUDA_ARCH_LIST=8.9
## `LLM_ENGINE_MODE` supports `sglang` and `vllm`.
LLM_ENGINE_MODE=sglang

#################### SGLang ####################
SGLANG_MEM_FRACTION_STATIC=0.15
SGLANG_MAX_RUNNING_REQUESTS=4
SGLANG_CONTEXT_LENGTH=4096
SGLANG_CHUNKED_PREFILL_SIZE=8192
SGLANG_MAX_PREFILL_TOKENS=8192

#################### vLLM ####################
VLLM_GPU_MEMORY_UTILIZATION=0.15
VLLM_BLOCK_SIZE=16
VLLM_MAX_MODEL_LEN=4096
VLLM_MAX_NUM_BATCHED_TOKENS=4096
VLLM_MAX_NUM_SEQS=4

#################### Flow ####################
ONNX2TRT_WORKSPACE_SIZE=16
FLOW_ESTIMATOR_COUNT=1
FLOW_ACTOR_NUM_GPUS=0.15
FLOW_ACTOR_COUNT=1
FLOW_DTYPE=fp16 # fp16, bf16, fp32 
FLOW_JIT=0
FLOW_TRT=1
FLOW_COMPILE=1

#################### Hift ####################
HIFT_ACTOR_NUM_GPUS=0.05
HIFT_ACTOR_COUNT=1
HIFT_COMPILE=1
